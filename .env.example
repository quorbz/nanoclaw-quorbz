# NanoClaw-Quorbz — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ─── Agent Identity ───────────────────────────────────────────────────────────
ASSISTANT_NAME=Elena          # Agent's name (matches their identity in groups/template/CLAUDE.md)

# ─── xAI / Grok ──────────────────────────────────────────────────────────────
# Recommended: store XAI_API_KEY in OneCLI vault and leave blank here.
# Fallback: set directly if OneCLI is not running on this machine.
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-reasoning   # Options: grok-4-1-fast-reasoning, grok-code-fast-1, grok-4-1-fast-non-reasoning

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # Bot token from @BotFather — one per agent

# ─── OneCLI Credential Vault ──────────────────────────────────────────────────
ONECLI_URL=http://127.0.0.1:10254    # Local OneCLI instance (preferred for credential injection)

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=America/Chicago            # IANA timezone for scheduled tasks

# ─── Optional Overrides ───────────────────────────────────────────────────────
# CONTAINER_IMAGE=nanoclaw-xai-agent:latest
# CONTAINER_TIMEOUT=1800000
# MAX_MESSAGES_PER_PROMPT=10
# IDLE_TIMEOUT=1800000
